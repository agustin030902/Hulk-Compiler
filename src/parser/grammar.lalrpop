use crate::lexer::TokenKind;
use crate::parser::expression::{
    BinaryExpr, BinaryOp, BuiltinCallExpr, BuiltinFunction, Expr, Literal, Program, Span,
    Statement, UnaryExpr, UnaryOp,
};

grammar;

extern {
    type Location = usize;
    type Error = String;

    enum TokenKind {
        "let" => TokenKind::Let,
        "print" => TokenKind::Print,
        "PI" => TokenKind::Pi,
        "E" => TokenKind::E,
        "sin" => TokenKind::Sin,
        "cos" => TokenKind::Cos,
        "sqrt" => TokenKind::Sqrt,
        "exp" => TokenKind::Exp,
        "log" => TokenKind::Log,
        "=" => TokenKind::Assign,
        "+" => TokenKind::Add,
        "^" => TokenKind::Power,
        "@" => TokenKind::Concat,
        "-" => TokenKind::Minus,
        "*" => TokenKind::Multiply,
        "/" => TokenKind::Divide,
        "==" => TokenKind::EqualEqual,
        "!=" => TokenKind::NotEqual,
        "<" => TokenKind::Less,
        ">" => TokenKind::Greater,
        "<=" => TokenKind::LessEqual,
        ">=" => TokenKind::GreaterEqual,
        "&&" => TokenKind::And,
        "||" => TokenKind::Or,
        "!" => TokenKind::Not,
        "," => TokenKind::Comma,
        ";" => TokenKind::Semicolon,
        "(" => TokenKind::LeftParen,
        ")" => TokenKind::RightParen,
        "identifier" => TokenKind::Identifier(<String>),
        "number" => TokenKind::Number(<String>),
        "string" => TokenKind::String(<String>),
        "boolean" => TokenKind::Boolean(<String>),
        "unknown" => TokenKind::Unknown,
        "eof" => TokenKind::EOF,
    }
}

pub Program: Program = {
    <statements:Statement*> "eof" => Program { statements },
};

Statement: Statement = {
    <l:@L> "let" <id:IdentifierWithSpan> "=" <value:Expr> ";" <r:@R> => Statement::Let {
        name: id.0,
        name_span: id.1,
        value,
        span: Span::new(l, r),
    },
    <l:@L> <id:IdentifierWithSpan> "=" <value:Expr> ";" <r:@R> => Statement::Assign {
        name: id.0,
        name_span: id.1,
        value,
        span: Span::new(l, r),
    },
    <l:@L> "print" "(" <value:Expr> ")" ";" <r:@R> => Statement::Print {
        value,
        span: Span::new(l, r),
    },
};

Expr: Expr = {
    LogicalOr,
};

LogicalOr: Expr = {
    <l:@L> <left:LogicalOr> "||" <right:LogicalAnd> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Or,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    LogicalAnd,
};

LogicalAnd: Expr = {
    <l:@L> <left:LogicalAnd> "&&" <right:Equality> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::And,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Equality,
};

Equality: Expr = {
    <l:@L> <left:Equality> "==" <right:Comparison> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Equal,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Equality> "!=" <right:Comparison> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::NotEqual,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Comparison,
};

Comparison: Expr = {
    <l:@L> <left:Comparison> "<" <right:Term> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Less,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Comparison> ">" <right:Term> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Greater,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Comparison> "<=" <right:Term> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::LessEqual,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Comparison> ">=" <right:Term> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::GreaterEqual,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Term,
};

Term: Expr = {
    <l:@L> <left:Term> "+" <right:Factor> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Add,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Term> "@" <right:Factor> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Concat,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Term> "-" <right:Factor> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Sub,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Factor,
};

Factor: Expr = {
    <l:@L> <left:Factor> "*" <right:Unary> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Mul,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    <l:@L> <left:Factor> "/" <right:Unary> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Div,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Unary,
};

Unary: Expr = {
    <l:@L> "!" <expr:Unary> <r:@R> => Expr::Unary(UnaryExpr {
        op: UnaryOp::Not,
        expr: Box::new(expr),
        span: Span::new(l, r),
    }),
    <l:@L> "-" <expr:Unary> <r:@R> => Expr::Unary(UnaryExpr {
        op: UnaryOp::Neg,
        expr: Box::new(expr),
        span: Span::new(l, r),
    }),
    Power,
};

Power: Expr = {
    <l:@L> <left:Primary> "^" <right:Unary> <r:@R> => Expr::Binary(BinaryExpr {
        left: Box::new(left),
        op: BinaryOp::Pow,
        right: Box::new(right),
        span: Span::new(l, r),
    }),
    Primary,
};

Primary: Expr = {
    <call:BuiltinCallExpr> => call,
    <literal:LiteralExpr> => literal,
    <variable:VariableExpr> => variable,
    "(" <expr:Expr> ")" => expr,
};

BuiltinCallExpr: Expr = {
    <l:@L> "sin" "(" <arg:Expr> ")" <r:@R> => Expr::BuiltinCall(BuiltinCallExpr {
        function: BuiltinFunction::Sin,
        args: vec![arg],
        span: Span::new(l, r),
    }),
    <l:@L> "cos" "(" <arg:Expr> ")" <r:@R> => Expr::BuiltinCall(BuiltinCallExpr {
        function: BuiltinFunction::Cos,
        args: vec![arg],
        span: Span::new(l, r),
    }),
    <l:@L> "sqrt" "(" <arg:Expr> ")" <r:@R> => Expr::BuiltinCall(BuiltinCallExpr {
        function: BuiltinFunction::Sqrt,
        args: vec![arg],
        span: Span::new(l, r),
    }),
    <l:@L> "exp" "(" <arg:Expr> ")" <r:@R> => Expr::BuiltinCall(BuiltinCallExpr {
        function: BuiltinFunction::Exp,
        args: vec![arg],
        span: Span::new(l, r),
    }),
    <l:@L> "log" "(" <base:Expr> "," <value:Expr> ")" <r:@R> => Expr::BuiltinCall(BuiltinCallExpr {
        function: BuiltinFunction::Log,
        args: vec![base, value],
        span: Span::new(l, r),
    }),
};

IdentifierWithSpan: (String, Span) = {
    <l:@L> <name:"identifier"> <r:@R> => (name, Span::new(l, r)),
};

VariableExpr: Expr = {
    <l:@L> <name:"identifier"> <r:@R> => Expr::Variable {
        name,
        span: Span::new(l, r),
    },
};

LiteralExpr: Expr = {
    <l:@L> "PI" <r:@R> => Expr::Literal {
        value: Literal::Float(std::f64::consts::PI),
        span: Span::new(l, r),
    },
    <l:@L> "E" <r:@R> => Expr::Literal {
        value: Literal::Float(std::f64::consts::E),
        span: Span::new(l, r),
    },
    <l:@L> <raw:"number"> <r:@R> =>? {
        if raw.contains('.') {
            match raw.parse::<f64>() {
                Ok(v) => Ok(Expr::Literal {
                    value: Literal::Float(v),
                    span: Span::new(l, r),
                }),
                Err(_) => Err(lalrpop_util::ParseError::User {
                    error: format!("Invalid float literal: {}", raw),
                }),
            }
        } else {
            match raw.parse::<i64>() {
                Ok(v) => Ok(Expr::Literal {
                    value: Literal::Integer(v),
                    span: Span::new(l, r),
                }),
                Err(_) => Err(lalrpop_util::ParseError::User {
                    error: format!("Invalid integer literal: {}", raw),
                }),
            }
        }
    },
    <l:@L> <raw:"boolean"> <r:@R> => Expr::Literal {
        value: Literal::Boolean(raw == "true"),
        span: Span::new(l, r),
    },
    <l:@L> <raw:"string"> <r:@R> => Expr::Literal {
        value: Literal::String(raw),
        span: Span::new(l, r),
    },
};
